<Window x:Class="Directory_Scanner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:Directory_Scanner.UI.Model"
        xmlns:converter="clr-namespace:Directory_Scanner.UI.Converter"
        mc:Ignorable="d"
        Title="Directory Scanner" Height="450" Width="800">
    <Window.DataContext>
        <model:MainWindowViewModel />
    </Window.DataContext>
    <Window.Resources>
        <converter:FileTypeToImageConverter x:Key="FileTypeToImageConverter" />
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"></converter:BoolToVisibilityConverter>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="Scan" Command="{Binding StartScanCommand}" Margin="5" Padding="10,2" Width="350"/>
            <Button Content="Cancel" Command="{Binding CancelScanCommand}" Margin="5" Padding="10,2" Width="350"/>
        </StackPanel>
        <TreeView Grid.Row="1" 
                  ItemsSource="{Binding RootItems}" 
                  Margin="5"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding Type, Converter={StaticResource FileTypeToImageConverter}}"
                               Width="16" Height="16" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding Name}" Margin="2"/>
                        <TextBlock Text=" (" Margin="2"/>
                        <TextBlock Text=")" Margin="2"/>
                        <TextBlock Text="(" Margin="2" 
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapsed}"/>
                        <TextBlock Text="{Binding Percent, StringFormat={}{0:F2}}" Margin="2"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapsed}"/>
                        <TextBlock Text="%)" Margin="2"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Collapsed}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</Window>